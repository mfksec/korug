# ============================================================================
# KÖRÜG - Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment
# 
# SECURITY WARNING: Never commit the actual .env file to version control!
# .env contains sensitive credentials and should be kept private.
# ============================================================================

# ============================================================================
# REQUIRED: Database Configuration
# ============================================================================
# PostgreSQL connection string for production
# Format: postgresql://user:password@host:port/database
# ⚠️ For local Docker: Use the postgres service hostname
# Example: postgresql://postgres:postgres_password@postgres:5432/korug
# IMPORTANT: Replace user and password with strong credentials!
DATABASE_URL=postgresql://your_username:your_strong_password@localhost:5432/korug

# Alternative for local development (SQLite):
# DATABASE_URL=sqlite:///./test.db

# ============================================================================
# REQUIRED: Security Configuration (Production Deployment)
# ============================================================================

# JWT Secret Key for token signing
# ⚠️ GENERATE A NEW KEY FOR PRODUCTION!
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Minimum 32 bytes. Must be cryptographically random.
JWT_SECRET_KEY=your-generated-jwt-secret-key-here-minimum-32-bytes

# API Key for REST API authentication
# ⚠️ GENERATE A NEW KEY FOR PRODUCTION!
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
API_KEY=your-generated-api-key-here-minimum-32-bytes

# Allowed CORS origins - comma-separated list
# For Docker: http://localhost:3000,http://localhost:8000
# For dev: http://localhost:3000,http://localhost:8000,http://localhost:5174
# Production: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5174

# ============================================================================
# RUNTIME: FastAPI Configuration
# ============================================================================

# Environment: development or production
# Set to 'production' to disable debug mode and enable security features
FASTAPI_ENV=development

# Debug mode - ⚠️ ALWAYS set to 'false' in production!
# Debug mode exposes stack traces and is a security risk
FASTAPI_DEBUG=true

# Server binding
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============================================================================
# OPTIONAL: Slack Integration (Real-time Notifications)
# ============================================================================

# Slack webhook URL for alerts
# Create at: https://api.slack.com/messaging/webhooks
# Format: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Enable/disable Slack notifications
SLACK_ENABLED=false

# ============================================================================
# OPTIONAL: External APIs (Enhanced Discovery)
# ============================================================================

# Shodan.io API key for IP/port intelligence
# Get from: https://www.shodan.io/api/
# If not provided, discovery will continue without Shodan data
SHODAN_API_KEY=your-shodan-api-key-here

# urlscan.io API key for URL archive data
# Get from: https://urlscan.io/api/
# If not provided, discovery will continue without urlscan data
URLSCAN_API_KEY=your-urlscan-api-key-here

# Additional passive sources (all optional — leave blank to skip).
# Many sources work with NO key (crt.sh, HackerTarget, CertSpotter, RapidDNS,
# AlienVault OTX, ThreatMiner, Wayback, BufferOver, ThreatCrowd); these keys
# only unlock extra providers.
VIRUSTOTAL_API_KEY=
SECURITYTRAILS_API_KEY=
BINARYEDGE_API_KEY=
# Censys Search v2 (https://search.censys.io/account/api) — both required
CENSYS_API_ID=
CENSYS_API_SECRET=

# ============================================================================
# OPTIONAL: Recon / Enrichment
# ============================================================================

# HTTP(S) probe each live subdomain (status code, title, server, technologies)
ENABLE_HTTP_PROBE=true

# Active port scan of resolved IPs. Off by default — only enable for targets
# you are authorized to scan. Can also be toggled per scan from the dashboard.
# Uses nmap (with service/version detection) when available, else a built-in
# async TCP connect scan.
ENABLE_PORT_SCAN=false
PORT_SCAN_PORTS=21,22,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443
NMAP_PATH=nmap
NMAP_SERVICE_DETECTION=true

# Max concurrent DNS/HTTP/port operations during enrichment
ENRICHMENT_CONCURRENCY=50
# Per-probe HTTP timeout (seconds)
HTTP_PROBE_TIMEOUT=8

# ============================================================================
# OPTIONAL: Discovery Tools Configuration
# ============================================================================

# Path to Subfinder executable (fast passive subdomain discovery)
# Install: brew install projectdiscovery/tools/subfinder
SUBFINDER_PATH=/usr/local/bin/subfinder

# Path to Amass executable (comprehensive subdomain discovery)
# Install: brew install amass
AMASS_PATH=/usr/local/bin/amass

# ============================================================================
# OPTIONAL: Scanning Configuration
# ============================================================================

# Confidence threshold for vulnerability alerts (0-100)
# Only vulnerabilities with confidence >= this value will alert
# Recommended: 75% (balanced) to 85% (conservative)
CONFIDENCE_THRESHOLD=75

# Scheduled daily scan time (UTC)
# Runs at SCAN_SCHEDULE_HOUR:SCAN_SCHEDULE_MINUTE every day
SCAN_SCHEDULE_HOUR=0
SCAN_SCHEDULE_MINUTE=0

# ============================================================================
# OPTIONAL: AWS Configuration (for S3 Takeover Detection)
# ============================================================================

# AWS region for S3 bucket operations
AWS_REGION=us-east-1

# ============================================================================
# OPTIONAL: Security Settings
# ============================================================================

# Enable rate limiting on login endpoint
ENABLE_RATE_LIMITING=true

# Rate limit format: "requests/time_period"
# Examples: "5/minute", "100/hour"
LOGIN_RATE_LIMIT=5/minute

# Use httpOnly + Secure cookies instead of localStorage
# Recommended: true for production
USE_HTTPONLY_COOKIES=false

# Secure cookie flag (auto-enabled in production)
# Set to true if using HTTPS
COOKIE_SECURE=false

# ============================================================================
# OPTIONAL: Advanced Configuration
# ============================================================================

# Maximum concurrent discovery tasks
MAX_DISCOVERY_WORKERS=4

# Timeout for external API calls (seconds)
API_TIMEOUT=30

# Maximum subdomains to process per domain
MAX_SUBDOMAINS_PER_DOMAIN=10000

# ============================================================================
# DOCKER-SPECIFIC NOTES:
# ============================================================================
# 
# When using Docker Compose, most values are overridden by the 
# docker-compose.yml file. Only change values here for local development.
#
# Database Host in Docker:
# Use 'postgres' instead of 'localhost' when connecting from within Docker:
# DATABASE_URL=postgresql://subdomain_user:subdomain_password@postgres:5432/korug
#
# ============================================================================

# ============================================================================
# SECURITY CHECKLIST FOR PRODUCTION:
# ============================================================================
# 
# ✅ Change FASTAPI_ENV to 'production'
# ✅ Set FASTAPI_DEBUG to 'false'
# ✅ Generate new JWT_SECRET_KEY (cryptographically random, 32+ bytes)
# ✅ Generate new API_KEY (cryptographically random, 32+ bytes)
# ✅ Set ALLOWED_ORIGINS to your actual domain(s)
# ✅ Use strong DATABASE_URL with proper credentials
# ✅ Enable HTTPS and set COOKIE_SECURE=true
# ✅ Set USE_HTTPONLY_COOKIES=true
# ✅ Add Slack webhook for notifications
# ✅ Change default admin password after first login
# ✅ Store .env in secure, non-public location
# ✅ Never commit .env to version control
# ✅ Use secrets management for sensitive values
# ✅ Regularly rotate API keys
# ✅ Enable audit logging (enabled by default)
# ✅ Monitor audit.log for security events
#
# ============================================================================

