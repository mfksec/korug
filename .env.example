# Database Configuration
DATABASE_URL=postgresql://subdomain_user:subdomain_password@localhost:5432/subdomain_hunter
# For testing: sqlite:///./test.db

# FastAPI Configuration
FASTAPI_ENV=development
FASTAPI_DEBUG=true
API_KEY=your-secret-api-key-here

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ENABLED=true

# Discovery Tools Configuration
SUBFINDER_PATH=/usr/local/bin/subfinder
AMASS_PATH=/usr/local/bin/amass

# External APIs (Optional)
SHODAN_API_KEY=your-shodan-api-key-here
URLSCAN_API_KEY=your-urlscan-api-key-here

# Scanning Configuration
SCAN_SCHEDULE_HOUR=0
SCAN_SCHEDULE_MINUTE=0
CONFIDENCE_THRESHOLD=75

# AWS S3 Configuration (for takeover detection)
AWS_REGION=us-east-1

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
